      "id": "512962f9-4148-4a8f-8a58-1558021632bd",
      "name": "Parse XML",
      "type": "n8n-nodes-base.xml",
      "typeVersion": 1,
      "position": [
        896,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const out = [];\nconst txt = (v) => {\n  if (v == null) return '';\n  if (typeof v === 'object') return v._ || v['#text'] || '';\n  return String(v);\n};\nfor (const it of $input.all()) {\n  const j = it.json || {};\n  const channel = (j.rss && j.rss.channel) ? j.rss.channel : j.channel;\n  if (!channel) continue;\n  let items = channel.item;\n  if (!items) continue;\n  if (!Array.isArray(items)) items = [items];\n  for (const a of items) {\n    let link = a.link;\n    if (typeof link === 'object') link = link.href || link._ || '';\n    const title = txt(a.title);\n    if (!link || !title) continue;\n    out.push({ json: {\n      title,\n      link: String(link).trim(),\n      pubDate: txt(a.pubDate) || txt(a['dc:date']) || '',\n      contentSnippet: txt(a.description).replace(/<[^>]*>/g, '').substring(0, 300)\n    }});\n  }\n}\nreturn out;"
      },
      "id": "71c00649-3a2f-4e0b-ac1a-06040b048104",
      "name": "Extract Articles",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
