      "id": "399d255f-930d-470a-a96e-12342df0e8f6",
      "name": "Remove Duplicate Articles",
      "type": "n8n-nodes-base.removeDuplicates",
      "typeVersion": 2,
      "position": [
        1344,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const cutoff = Date.now() - 86400000;\nconst articles = $input.all()\n  .filter(item => {\n    const d = item.json.isoDate || item.json.pubDate;\n    if (!d) return false;\n    const t = new Date(d).getTime();\n    return !isNaN(t) && t > cutoff;\n  })\n  .map(item => item.json);\n\nif (articles.length === 0) {\n  throw new Error('No articles found in last 24h');\n}\n\nconst list = articles.slice(0, 100).map((a, i) =>\n  (i + 1) + '. ' + (a.title || 'No title') + '\\n' +\n  'URL: ' + (a.link || '') + '\\n' +\n  'Опис: ' + ((a.contentSnippet || a.description || '').substring(0, 250))\n).join('\\n\\n');\n\nconst prompt = 'Ти — редактор новин. Завдання:\\n' +\n  '1. Відібрати ТОП-10 найважливіших новин зі списку\\n' +\n  '2. Написати 5 скриптів для YouTube Shorts (30-60 сек, 80-120 слів, 1 short = 1 новина)\\n' +\n  '3. Написати 1 скрипт для YouTube відео 16:9 (2-3 хв, 300-400 слів, всі 10 новин)\\n' +\n  'Мова — виключно українська. Журналістський стиль, без кліше.\\n\\n' +\n  'Відповідай ТІЛЬКИ JSON:\\n' +\n  '{\"top10\":[{\"title\":\"\",\"url\":\"\"}],' +\n  '\"shorts\":[' +\n  '{\"number\":1,\"title\":\"\",\"script\":\"\",\"source_urls\":[\"\"]},' +\n  '{\"number\":2,\"title\":\"\",\"script\":\"\",\"source_urls\":[\"\"]},' +\n  '{\"number\":3,\"title\":\"\",\"script\":\"\",\"source_urls\":[\"\"]},' +\n  '{\"number\":4,\"title\":\"\",\"script\":\"\",\"source_urls\":[\"\"]},' +\n  '{\"number\":5,\"title\":\"\",\"script\":\"\",\"source_urls\":[\"\"]}],' +\n  '\"long\":{\"title\":\"\",\"script\":\"\",\"source_urls\":[\"\"]}}\\n\\n' +\n  'Список новин (' + articles.length + ' статей):\\n\\n' + list;\n\nreturn [{ json: { prompt, articleCount: articles.length } }];"
      },
      "id": "7dfb6e2b-af43-4c87-a9ec-d4164cbe3101",
      "name": "Filter 24h + Build Prompt",
