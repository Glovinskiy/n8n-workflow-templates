      "id": "9e9b9b3c-3e28-4ed5-9ea2-f0c605434fe2",
      "name": "OpenAI — Generate Scripts",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.3,
      "position": [
        1792,
        0
      ],
      "credentials": {
        "openAiApi": {
          "name": "OpenAi_main"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const j = $input.first().json;\n\nfunction deepFindJson(root) {\n  let found = null;\n  const walk = (v) => {\n    if (found) return;\n    if (v && typeof v === 'object' && !Array.isArray(v) && (v.shorts || v.long)) {\n      found = v; return;\n    }\n    if (typeof v === 'string') {\n      const t = v.replace(/^```json\\s*/i, '').replace(/```$/i, '').trim();\n      if (t.startsWith('{') && (t.includes('\"shorts\"') || t.includes('\"long\"'))) {\n        try { found = JSON.parse(t); } catch (e) {}\n      }\n    } else if (Array.isArray(v)) {\n      v.forEach(walk);\n    } else if (v && typeof v === 'object') {\n      Object.values(v).forEach(walk);\n    }\n  };\n  walk(root);\n  return found;\n}\n\nconst parsed = deepFindJson(j);\n\nif (!parsed) {\n  throw new Error('Не знайшов JSON зі скриптами. item: ' + JSON.stringify(j).substring(0, 500));\n}\n\nconst today = new Date().toISOString().split('T')[0];\nconst items = [];\n\nfor (const s of (parsed.shorts || [])) {\n  items.push({ json: {\n    title: s.title || ('Short ' + s.number),\n    script: s.script || '',\n    format: 'Short',\n    short_number: s.number,\n    source_urls: (s.source_urls || []).join(', '),\n    news_date: today\n  }});\n}\n\nconst long = parsed.long || {};\nitems.push({ json: {\n  title: long.title || 'Дайджест новин',\n  script: long.script || '',\n  format: '16:9',\n  short_number: null,\n  source_urls: (long.source_urls || []).join(', '),\n  news_date: today\n}});\n\nreturn items;\n"
      },
