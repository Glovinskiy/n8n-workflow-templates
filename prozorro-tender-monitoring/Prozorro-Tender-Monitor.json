      ],
      "id": "5fef0c3d-0d36-4b9f-ae07-6aa0c0fc0fa6",
      "name": "Filter Tenders1"
    },
    {
      "parameters": {
        "jsCode": "const d = $json.data;\nconst toDate = (val) => { if (!val) return ''; return val.split('T')[0] || ''; };\n\nconst entity = d.procuringEntity || {};\nconst contact = entity.contactPoint || {};\nconst entityAddress = entity.address || {};\nconst item = (d.items || [])[0] || {};\nconst deliveryAddress = item.deliveryAddress || {};\nconst city = entityAddress.locality || entityAddress.streetAddress || deliveryAddress.locality || '—';\nconst region = entityAddress.region || deliveryAddress.region || '—';\nconst documents = (d.documents || [])\n  .filter(doc => doc.confidentiality === 'public')\n  .map(doc => ({ title: doc.title || doc.documentType || '—', url: doc.url || '—' }));\n\nconst awardsMap = {};\nfor (const award of (d.awards || [])) {\n  if (award.bid_id) awardsMap[award.bid_id] = award.value?.amount;\n}\nconst participants = (d.bids || []).map(bid => {\n  const tenderer = (bid.tenderers || [])[0] || {};\n  const cp = tenderer.contactPoint || {};\n  return {\n    name: tenderer.name || '—',\n    edrpou: tenderer.identifier?.id || '—',\n    email: cp.email || '—',\n    phone: cp.telephone || '—',\n    initialBid: bid.value?.amount || 0,\n    finalBid: awardsMap[bid.id] || bid.value?.amount || 0,\n    date: bid.date ? bid.date.split('T')[0] : '—'\n  };\n});\n\nif (d.status !== 'active.tendering') {\n  return { json: {\n    _skip: true,\n    tenderID: d.tenderID,\n    orgName: entity.name || '—',\n    edrpou: entity.identifier?.id || '—',\n    city, region,\n    contactName: contact.name || '—',\n    email: contact.email || '—',\n    phone: contact.telephone || '—',\n    title: d.title || '—',\n    amount: d.value?.amount || 0,\n    cpv: item.classification?.id || '—',\n    url: `https://prozorro.gov.ua/tender/${d.tenderID}`,\n    participants: JSON.stringify(participants),\n    documents: JSON.stringify(documents)\n  }};\n}\n\nreturn { json: {\n  _skip: false,\n  tenderID: d.tenderID, orgName: entity.name || '—', edrpou: entity.identifier?.id || '—',\n  city, region, contactName: contact.name || '—', email: contact.email || '—',\n  phone: contact.telephone || '—', title: d.title || '—', amount: d.value?.amount || 0,\n  cpv: item.classification?.id || '—', url: `https://prozorro.gov.ua/tender/${d.tenderID}`,\n  datePublished: toDate(d.datePublished), enquiryEnd: toDate(d.enquiryPeriod?.endDate),\n  tenderEnd: toDate(d.tenderPeriod?.endDate), auctionStart: toDate(d.auctionPeriod?.startDate),\n  documents: JSON.stringify(documents)\n}};\n"
      },
