{
  "name": "Tenderts",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const tenders = $('HTTP Request').item.json.data || [];\nreturn tenders.map(t => ({ json: t }));\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1136,
        112
      ],
      "id": "6c079eda-78bd-49dc-a44a-8b54df5da003",
      "name": "Split Tenders"
    },
    {
      "parameters": {
        "url": "=https://public.api.openprocurement.org/api/2.5/tenders/{{ $json.id }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        -928,
        112
      ],
      "id": "f0c75193-7b63-4528-a7a3-e7f2b7cc391f",
      "name": "Get Tender Details",
      "retryOnFail": true,
      "waitBetweenTries": 5000,
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const d = $json.data;\n\nconst CPV_CODES = ['31154000-0', '31434000-7', '31430000-9'];\nconst BRANDS = [\n  'anker', 'solix', 'zendure', 'bluetti', 'marstek', 'jackery',\n  'apstorage', 'apsystems', 'everhome', 'hoymiles', 'novgen',\n  'shelly', 'tuya', 'tentek', 'jolywood'\n];\nconst MIN_AMOUNT = 50000;\nconst ALLOWED_TYPES = ['belowThreshold', 'aboveThreshold', 'aboveThresholdEU', 'aboveThresholdUA', 'priceQuotation'];\n\nif (!ALLOWED_TYPES.includes(d.procurementMethodType)) return { json: { matched: false } };\nif ((d.value?.amount || 0) < MIN_AMOUNT) return { json: { matched: false } };\n\nlet matched = false;\nfor (const item of (d.items || [])) {\n  if (CPV_CODES.includes(item.classification?.id || '')) { matched = true; break; }\n}\nif (!matched) {\n  const text = ((d.title || '') + ' ' + (d.description || '')).toLowerCase();\n  if (BRANDS.some(b => text.includes(b))) matched = true;\n}\n\nif (!matched) return { json: { matched: false } };\n\nreturn {\n  json: {\n    matched: true,\n    data: {\n      tenderID: d.tenderID,\n      status: d.status,\n      procurementMethodType: d.procurementMethodType,\n      title: d.title,\n      value: d.value,\n      datePublished: d.datePublished,\n      enquiryPeriod: d.enquiryPeriod,\n      tenderPeriod: d.tenderPeriod,\n      auctionPeriod: d.auctionPeriod,\n      procuringEntity: d.procuringEntity,\n      items: d.items,\n      documents: d.documents,\n      bids: d.bids,\n      awards: d.awards\n    }\n  }\n};\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -688,
        112
      ],
      "id": "da003d4f-3e12-48c4-b96e-8313c443a64a",
      "name": "Filter Tenders"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "5b2c659d-7839-4fcf-8123-60cf153d7297",
              "leftValue": "={{ $json.matched }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        -2048,
