    {
      "parameters": {
        "jsCode": "const cleanUrl = (u) => String(u || '').trim().split('?')[0].replace(/\\/+$/, '');\nconst out = [];\nfor (const item of $input.all()) {\n  const d = item.json;\n  let link = d.link;\n  if (link && typeof link === 'object') link = link._ || link.href || '';\n  const url = cleanUrl(link);\n  if (!url) continue;\n  const desc = String(d.description || '').replace(/<[^>]+>/g, ' ').replace(/\\s+/g, ' ').trim().slice(0, 600);\n  out.push({ json: {\n    url, source: 'dou',\n    title: String(d.title || '').trim(),\n    company: '',\n    snippet: desc, salary: '', location: '',\n    posted_at: String(d.pubDate || '').trim(),\n  }});\n}\nreturn out;\n"
      },
