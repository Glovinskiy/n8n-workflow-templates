    {
      "parameters": {
        "jsCode": "const cleanUrl = (u) => String(u || '').trim().split('?')[0].replace(/\\/+$/, '');\nconst out = [];\nfor (const item of $input.all()) {\n  const d = item.json;\n  let link = d.link;\n  if (link && typeof link === 'object') link = link._ || link.href || '';\n  const url = cleanUrl(link);\n  if (!url) continue;\n  const titleRaw = String(d.title || '').trim();\n  let company = '', title = titleRaw;\n  const idx = titleRaw.indexOf(':');\n  if (idx > -1) { company = titleRaw.slice(0, idx).trim(); title = titleRaw.slice(idx + 1).trim(); }\n  const desc = String(d.description || d.content || '').replace(/<[^>]+>/g, ' ').replace(/\\s+/g, ' ').trim().slice(0, 600);\n  out.push({ json: {\n    url, source: 'wwr', title, company,\n    snippet: desc, salary: '', location: 'Remote',\n    posted_at: String(d.pubDate || '').trim(),\n  }});\n}\nreturn out;\n"
      },
      "id": "c3a49c17-a132-4e4a-ba69-60baf625fba9",
      "name": "Normalize WWR",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        896,
        384
      ]
    },
    {
      "parameters": {
        "jsCode": "// ── Keyword Pre-Filter ───────────────────────────────────────────\n// STRONG     — однозначні маркери, ловимо будь-де (title або опис)\n// TITLE_HINTS — слабкі маркери, тільки в заголовку (бо в описах бузворди скрізь)\n// TITLE_BLOCK — ролі-сміття, ріжемо одразу\n\nconst STRONG = [\n  'n8n', 'no-code', 'nocode', 'low-code', 'make.com', 'zapier',\n  'manychat', 'voiceflow', 'langchain', 'retell', 'vapi', 'rpa'\n];\n\nconst TITLE_HINTS = [\n  'automation', 'integration', 'workflow', 'chatbot',\n  'ai engineer', 'ai developer', 'ai automation', 'prompt engineer',\n  'ai agent', 'no code', 'automation engineer', 'integration engineer'\n];\n\nconst TITLE_BLOCK = [\n  'assistant', 'data entry', 'sales', 'sdr', 'closer', 'recruiter',\n  'designer', 'officer', 'manager', 'interdiction', 'content creator',\n  'executive', 'analyst', 'agilista', 'accountant', 'marketer',\n  'nurse', 'driver'\n];\n\nconst out = [];\nfor (const item of $input.all()) {\n  const title = String(item.json.title || '').toLowerCase();\n  const blob = (title + ' ' + String(item.json.snippet || '')).toLowerCase();\n\n  if (TITLE_BLOCK.some(b => title.includes(b))) continue;\n\n  const strong = STRONG.some(k => blob.includes(k));\n  const titleHit = TITLE_HINTS.some(k => title.includes(k));\n\n  if (strong || titleHit) out.push({ json: item.json });\n}\n\nreturn out;\n"
      },
      "id": "244b3795-918c-4cc7-8131-d8579f9a8702",
      "name": "Keyword Pre-Filter",
