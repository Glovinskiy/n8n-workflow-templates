    {
      "parameters": {
        "jsCode": "const cleanUrl = (u) => String(u || '').trim().split('?')[0].replace(/\\/+$/, '');\nconst out = [];\nfor (const item of $input.all()) {\n  const d = item.json;\n  if (d.legal != null || !d.position) continue;\n  const desc = String(d.description || '').replace(/<[^>]+>/g, ' ').replace(/\\s+/g, ' ').trim().slice(0, 600);\n  let sal = '';\n  if (d.salary_min) sal = '$' + d.salary_min + '-' + (d.salary_max || '');\n  out.push({ json: {\n    url: cleanUrl(d.url), source: 'remoteok',\n    title: String(d.position || '').trim(),\n    company: String(d.company || '').trim(),\n    snippet: desc, salary: sal,\n    location: String(d.location || 'Remote').trim(),\n    posted_at: String(d.date || '').trim(),\n  }});\n}\nreturn out;\n"
      },
